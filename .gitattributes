# Normalize line endings so CI shell steps behave the same everywhere.
# CRLF in a file consumed by bash (e.g. workflow `run:` blocks or the DMG/icon
# helper scripts on macOS/Linux runners) produces `$'\r': command not found`
# errors, so force LF for text formats that get executed or parsed cross-platform.
* text=auto eol=lf

# Explicitly keep these LF regardless of the committer's autocrlf setting.
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.iss text eol=lf
*.rst text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Binary assets must never be line-ending converted.
*.png binary
*.ico binary
*.icns binary
*.pdf binary
*.dmg binary
